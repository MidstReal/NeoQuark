$share(print)
$share(read)
$share(exit)
$share(strlen)

func print
    rsi = rax 
    rdx = rcx
    rax = 1
    rdi = 1
    syscall
end

func read
    rdx = rax
    rsi = rcx
    rdi = 0
    rax = 0
    syscall
end

func exit
    rax = 60
    syscall
end

func strlen
    rax ^= rax
func .loop
    if([rdi + rax], ==, 0, .done, 1b)
    rax ++
    goto(.loop)
func .done
end
