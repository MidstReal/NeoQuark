; compile:
; ./nquark test/main.nqk -o test/temp.asm -64
; nasm -f elf64 test/temp.asm -o test/prog.o

; code for version 26-7

$share(_start)
$section(.text)

func _start
    print(msg, 23)
    syscall(60)

func print
    rsi = rax
    rdx = rcx
    rdi = 1
    syscall(1)
end

$section(.data)

char msg = "Hello, Linux!",10