; code for version 26-7

$share(_start)
$include("libs/linux.asm")

$section(.text)

func _start

    ; mov [msg+0], 'B'
    ; mov [msg+1], 'y'
    ; mov [msg+2], 'e'
    ; ...
    msg r= "Bye, Linux!  "

    print(msg, 23)
    exit

$section(.data)

char msg = "Hello, Linux!",10