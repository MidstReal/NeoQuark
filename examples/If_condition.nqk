; compile:
; ./nquark test/main.nqk -o test/temp.asm -64
; nasm -f elf64 test/temp.asm -o test/prog.o

; code for version 26-7

$share(_start)
$section(.text)

func _start
    ; cmp byte [a], 3
    ; jne test
    if([a], !=, 3, test, b)

    syscall(60)

func test
    print&(msg, 23)

    ; inc byte [a]
    [a] b++

    goto(_start)


func print
hsf
    rsi = [rbp+24]
    rdx = [rbp+16]
    rdi = 1
    syscall(1)
endsf

$section(.data)

char msg = "Hello, Linux!",10
byte a = 0